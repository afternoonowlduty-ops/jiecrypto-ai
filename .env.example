# Copy this file to ".env" and fill in your API key(s).
# Get free keys at https://platform.agnes-ai.com/settings/apiKeys (no credit card required).

# Add as many numbered keys as you like — the server picks them all up
# automatically and rotates between them (round-robin with failover).
# Just keep numbering: AGNES_API_KEY_4, AGNES_API_KEY_5, ...
AGNES_API_KEY_1=sk-your-key-here
AGNES_API_KEY_2=
AGNES_API_KEY_3=

# API base URL (do not change unless the provider updates their endpoint).
AGNES_BASE_URL=https://apihub.agnes-ai.com

# Port the local server listens on.
PORT=3000
